<section
  id="main-search-{{ section.id }}"
  class="full-width w-full py-20"
  style="background: var(--background);"
>
  <div
    class="px-6"
    style="max-width: var(--page-width); margin-inline: auto;"
  >
    {%- # Search header: System Query Style -%}
    <div
      class="mb-16 border-b pb-12"
      style="border-color: var(--border);"
      data-gsap="fade-up"
      data-scroll="true"
    >
      <div class="mb-4 flex items-center gap-3">
        <span class="bg-primary h-2 w-2 animate-pulse rounded-full"></span>
        <p class="text-primary font-mono text-[10px] tracking-[0.3em] uppercase">System_Query // Global_Search</p>
      </div>

      <h1
        class="text-foreground mb-8 pb-2 text-5xl font-bold tracking-tighter uppercase md:text-6xl"
        style="font-family: var(--font-headline);"
      >
        Search
      </h1>

      {%- # Search input: Tech-Framed -%}
      <form
        action="{{ routes.search_url }}"
        method="get"
        role="search"
        class="flex flex-col gap-4 md:flex-row md:items-center"
      >
        <div class="group relative flex-1">
          <input
            type="search"
            name="q"
            value="{{ search.terms | escape }}"
            placeholder="INPUT PARAMETERS..."
            class="text-foreground placeholder:text-foreground/20 w-full py-4 pr-4 pl-12 font-mono text-xs transition-all duration-300 outline-none"
            style="background: var(--card); border: 1px solid var(--border); border-radius: 0;"
            data-gsap="focus-glow"
            autofocus
          >
          <svg
            class="text-primary/40 group-focus-within:text-primary absolute top-1/2 left-4 -translate-y-1/2 transition-colors"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <div class="border-primary/30 absolute top-0 right-0 h-2 w-2 border-t border-r"></div>
        </div>

        <button
          type="submit"
          class="inline-flex items-center justify-center gap-3 px-8 py-4 font-mono text-[10px] tracking-[0.2em] uppercase transition-all duration-300 hover:brightness-125"
          style="background: var(--primary); color: var(--primary-foreground); clip-path: polygon(10% 0, 100% 0, 90% 100%, 0% 100%);"
          data-gsap="hover-lift"
        >
          Execute_Search
        </button>
      </form>
    </div>

    {%- # Results logic -%}
    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <div
          class="mb-10 flex items-center justify-between"
          data-gsap="fade-up"
          data-scroll="true"
        >
          <p class="text-foreground/40 font-mono text-[10px] tracking-widest uppercase">
            Matches Found: <span class="text-foreground">{{ search.results_count }}</span> // Query:
            <span class="text-primary">"{{ search.terms }}"</span>
          </p>
        </div>

        <div
          class="bg-border grid grid-cols-2 gap-px md:grid-cols-3 lg:grid-cols-4"
          style="border: 1px solid var(--border);"
          data-gsap="stagger-fade-up"
          data-scroll="true"
          data-stagger="0.05"
        >
          {%- for item in search.results -%}
            <div class="bg-background group relative overflow-hidden p-4">
              {%- if item.object_type == 'product' -%}
                <a href="{{ item.url }}" class="flex flex-col gap-4">
                  <div class="bg-secondary relative aspect-[3/4] overflow-hidden">
                    {%- if item.featured_image -%}
                      <img
                        src="{{ item.featured_image | image_url: width: 600 }}"
                        alt="{{ item.featured_image.alt | escape }}"
                        class="h-full w-full object-cover grayscale transition-all duration-500 group-hover:scale-110 group-hover:grayscale-0"
                        loading="lazy"
                      >
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'h-full w-full object-cover opacity-20' }}
                    {%- endif -%}

                    <div class="bg-primary/10 pointer-events-none absolute inset-0 flex items-center justify-center opacity-0 transition-opacity group-hover:opacity-100">
                      <span class="text-primary border-primary bg-background border px-2 py-1 font-mono text-[9px]"
                        >VIEW_DETAILS</span
                      >
                    </div>
                  </div>

                  <div class="flex flex-col gap-1">
                    <span class="text-primary font-mono text-[8px] tracking-tighter uppercase"
                      >Inventory_ID: {{ item.id | last: 6 -}}
                    </span>
                    <h3 class="text-foreground truncate text-sm leading-none font-bold tracking-tight uppercase">
                      {{ item.title }}
                    </h3>
                    <span class="text-foreground/60 font-mono text-xs">
                      {{ item.price | money }}
                    </span>
                  </div>
                </a>

              {%- else -%}
                {%- # Generic Result (Pages/Articles) -%}
                <a href="{{ item.url }}" class="flex h-full min-h-[200px] flex-col justify-between">
                  <p class="text-primary font-mono text-[9px] tracking-widest uppercase">[{{ item.object_type }}]</p>
                  <h3 class="text-foreground mt-2 text-lg leading-tight font-bold uppercase">
                    {{ item.title }}
                  </h3>
                  <div class="mt-auto pt-4">
                    <span class="text-foreground/40 font-mono text-[10px] uppercase underline underline-offset-4"
                      >Read_More</span
                    >
                  </div>
                </a>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>

      {%- else -%}
        {%- # No Results: System Error State -%}
        <div
          class="flex flex-col items-center justify-center gap-6 py-40 text-center"
          data-gsap="fade-up"
          data-scroll="true"
        >
          <div class="relative">
            <svg
              width="64"
              height="64"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="0.5"
              class="text-primary animate-pulse"
            >
              <path d="M12 2L3.5 7v10L12 22l8.5-5V7L12 2z" />

              <line x1="12" y1="8" x2="12" y2="12" />
              <line x1="12" y1="16" x2="12.01" y2="16" stroke-linecap="round" stroke-width="2" />

              <path d="M7 21L3 21L3 17" stroke-width="1" />
              <path d="M17 21L21 21L21 17" stroke-width="1" />
              <path d="M7 3L3 3L3 7" stroke-width="1" />
              <path d="M17 3L21 3L21 7" stroke-width="1" />
            </svg>
          </div>

          <div class="space-y-2">
            <h2
              class="text-foreground text-3xl font-bold tracking-tighter uppercase"
              style="font-family: var(--font-headline);"
            >
              Query_No_Matches
            </h2>
            <p class="text-foreground/40 mx-auto max-w-sm font-mono text-xs leading-relaxed uppercase">
              Search parameter <span class="text-primary">"{{ search.terms }}"</span> yielded zero results in current
              database index.
            </p>
          </div>

          <a
            href="/collections/all"
            class="text-foreground border-border hover:bg-primary hover:text-background mt-6 inline-flex items-center gap-3 border px-8 py-4 font-mono text-[10px] tracking-[0.2em] uppercase transition-all duration-300"
          >
            Return_to_Archive
          </a>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Search",
  "tag": "section",
  "class": "site-search-section",
  "settings": []
}
{% endschema %}
