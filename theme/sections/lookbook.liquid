<section
  id="lookbook-{{ section.id }}"
  class="bg-grid-texture bg-background border-border relative overflow-hidden border-b"
>
  <div class="flex min-h-screen flex-col lg:flex-row">
    <div class="border-border relative h-[70vh] w-full overflow-hidden border-r lg:h-screen lg:w-1/2">
      <img
        src="{{ 'testimonial.jpeg' | asset_url }}"
        alt="Operational Field Test"
        class="absolute inset-0 h-full w-full origin-center object-cover brightness-50 contrast-125 grayscale"
        data-gsap="parallax"
      >

      <div class="from-background/80 absolute inset-0 bg-gradient-to-t via-transparent to-transparent"></div>

      <div class="absolute top-12 left-12 flex items-center gap-4">
        <div class="bg-primary h-1.5 w-1.5 animate-pulse rounded-full shadow-[0_0_8px_#4ade80]"></div>
        <p class="font-mono text-[10px] tracking-[0.4em] text-white/40 uppercase">Live_Feed // Operational</p>
      </div>

      <div class="absolute bottom-12 left-12" data-gsap="fade-in" data-scroll="true">
        <p class="text-foreground/90 font-mono text-[11px] tracking-widest uppercase">Subject: 08-X // Terrain_Test</p>
        <div class="bg-primary/50 mt-2 h-[1px] w-12"></div>
      </div>
    </div>

    <div class="bg-background flex w-full flex-col justify-center px-8 py-24 lg:w-1/2 lg:px-24">
      <div class="mx-auto max-w-xl space-y-24">
        <div
          data-gsap="fade-up"
          data-scroll="true"
          data-scroll-start="top 90%"
          data-delay="0.2"
        >
          <p
            class="text-primary typewriter-cursor mb-10 pb-5 font-mono text-[11px] tracking-[0.5em] uppercase"
            data-gsap="typewriter"
          >
            User_Testimonial
          </p>
          <h2 class="font-headline text-foreground pb-4 text-5xl leading-[0.8] font-black tracking-tighter uppercase italic lg:text-7xl">
            "Propulsion <br>
            over <br>
            <span class="text-transparent" style="-webkit-text-stroke: 1.5px var(--primary);">Protection</span>."
          </h2>
          <p class="text-muted-foreground font-body mt-10 max-w-md text-base leading-relaxed">
            The response time of the carbon chassis is immediate. On steep inclines, the energy return feels less like a
            cushion and more like a mechanical spring.
          </p>
        </div>

        <div
          class="grid grid-cols-2 gap-12 border-y border-white/5 py-12"
          data-gsap="fade-up"
          data-scroll="true"
          data-scroll-start="top 90%"
          data-delay="0.4"
        >
          <div class="space-y-2">
            <p class="text-foreground font-headline text-5xl font-black italic">
              94<span class="text-primary text-lg">%</span>
            </p>
            <p class="text-muted-foreground font-mono text-[9px] tracking-widest uppercase">Energy_Return</p>
          </div>
          <div class="space-y-2">
            <p class="text-foreground font-headline text-5xl font-black italic">
              210<span class="text-primary text-lg">g</span>
            </p>
            <p class="text-muted-foreground font-mono text-[9px] tracking-widest uppercase">Total_Mass</p>
          </div>
        </div>

        <div
          class="border-forground/5 border bg-white/[0.02] p-10 backdrop-blur-sm"
          data-gsap="fade-up"
          data-scroll="true"
          data-scroll-start="top 90%"
          data-delay="0.6"
        >
          <p
            class="text-foreground typewriter-cursor mb-6 flex items-center gap-3 font-mono text-[11px] tracking-widest uppercase"
            data-gsap="typewriter"
          >
            <span class="bg-primary h-2 w-[1px]"></span> Field_Note_//
          </p>
          <p
            class="text-muted-foreground typewriter-cursor max-w-sm font-mono text-[10px] leading-relaxed tracking-tight uppercase"
            data-gsap="typewriter"
          >
            Tested in Sector_04 under heavy precipitation. Traction integrity maintained at 98.4% efficiency. Zero
            thermal degradation reported.
          </p>
        </div>

        <div
          class="flex items-center gap-6 pt-5"
          data-gsap="fade-up"
          data-scroll="true"
          data-scroll-start="top 90%"
          data-delay="0.8"
        >
          <div class="border-primary/20 bg-primary/5 text-primary flex h-16 w-16 items-center justify-center rounded-full border font-mono text-sm font-bold italic">
            AV
          </div>
          <div class="space-y-1">
            <p
              class="text-foreground typewriter-cursor font-mono text-xs font-bold tracking-widest uppercase"
              data-gsap="typewriter"
            >
              A_Vandervelt
            </p>
            <p
              class="text-muted-foreground typewriter-cursor font-mono text-[9px] tracking-tighter uppercase"
              data-gsap="typewriter"
            >
              Lead_Field_Agent // Pro_Trialist
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
