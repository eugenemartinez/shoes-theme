<section
  id="brand-ticker-{{ section.id }}"
  class="border-border bg-background w-full overflow-hidden border-y py-4 lg:py-8"
>
  <div class="flex py-2 whitespace-nowrap" data-gsap="ticker-left">
    {%- for i in (1..6) -%}
      <div class="flex items-center gap-8 px-4">
        <span class="font-headline text-primary text-5xl font-black tracking-tighter uppercase italic lg:text-7xl">
          Engineered for Motion
        </span>
        <span class="bg-foreground/20 h-3 w-3 rounded-full"></span>
        <span class="text-foreground/50 font-mono text-xl font-light tracking-[0.3em] uppercase"> v1.026_EST </span>
        <span class="bg-foreground/20 h-3 w-3 rounded-full"></span>
      </div>
    {%- endfor -%}
  </div>

  <div class="flex items-center justify-between px-10 py-2 opacity-20">
    <div class="bg-foreground h-[1px] flex-1"></div>
    <div
      class="text-foreground/70 px-4 font-mono text-[8px] tracking-[0.5em] uppercase"
      data-gsap="typewriter"
    >
      System_Diagnostic_Running
    </div>
    <div class="bg-foreground h-[1px] flex-1"></div>
  </div>

  <div class="flex py-2 whitespace-nowrap" data-gsap="ticker-right">
    {%- for i in (1..6) -%}
      <div class="flex items-center gap-8 px-4">
        <span
          class="font-headline text-5xl font-black tracking-tighter text-transparent uppercase italic lg:text-7xl"
          style="-webkit-text-stroke: 1px var(--foreground); opacity: 0.3;"
        >
          Blue Hour Series
        </span>
        <span class="text-foreground font-mono text-xl font-bold"> // 0{{ i }} </span>
      </div>
    {%- endfor -%}
  </div>
</section>
