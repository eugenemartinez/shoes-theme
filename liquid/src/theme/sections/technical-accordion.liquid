<section
  id="faq-{{ section.id }}"
  class="bg-grid-texture bg-background border-border relative flex justify-center border-b py-24 lg:py-32"
>
  <div class="mx-auto max-w-7xl px-8">
    <div class="flex flex-col gap-16 lg:flex-row lg:items-center lg:gap-32">
      <div class="h-fit w-full lg:sticky lg:top-32 lg:w-1/3">
        <div class="space-y-6" data-gsap="fade-up" data-scroll="true">
          <p
            class="text-primary typewriter-cursor font-mono text-[10px] tracking-[0.5em] uppercase"
            data-gsap="typewriter"
          >
            System_Queries // FAQ
          </p>
          <h2 class="text-foreground font-headline text-5xl leading-[0.9] font-black tracking-tighter uppercase italic">
            Technical <br>
            <span class="text-transparent" style="-webkit-text-stroke: 1px var(--foreground);">Intelligence</span>
          </h2>
          <div class="pt-8">
            <div class="mb-2 flex items-center gap-3">
              <div class="bg-primary h-1.5 w-1.5 animate-pulse rounded-full"></div>
              <p
                class="text-foreground typewriter-cursor font-mono text-[9px] tracking-widest uppercase"
                data-gsap="typewriter"
              >
                Server_Status: Optimal
              </p>
            </div>
            <p
              class="text-muted-foreground typewriter-cursor max-w-[240px] font-mono text-[9px] leading-relaxed uppercase"
              data-gsap="typewriter"
            >
              All technical parameters and mechanical specifications are verified for Archive_001.
            </p>
          </div>
        </div>
      </div>

      <div class="w-full lg:w-2/3">
        <div class="divide-y divide-white/10 border-t border-white/10 lg:border-t-0">
          {% assign questions = 'How does the Carbon_Chassis affect energy return?|Is the Kinetic_Mesh waterproof?|What is the estimated lifecycle of the outsole?'
            | split: '|'
          %}
          {% assign answers = 'The chassis uses a dual-density carbon weave that compresses under vertical load and snaps back at 94% efficiency. This provides a mechanical advantage during uphill sprints and rapid direction changes.|While not fully waterproof to maintain breathability, the mesh is treated with a DWR (Durable Water Repellent) coating that sheds precipitation in Sector_04 environments while allowing internal thermal regulation.|Engineered for 800km of high-impact terrain. The high-abrasion rubber compound is designed to wear evenly, maintaining traction integrity throughout the lifecycle of the silhouette.'
            | split: '|'
          %}

          {% for question in questions %}
            <div
              class="faq-item group"
              data-gsap="fade-up"
              data-scroll="true"
              data-delay="0.{{ forloop.index }}"
            >
              <button class="faq-trigger flex w-full cursor-pointer items-center justify-between py-10 text-left outline-none">
                <span class="flex items-center gap-8">
                  <span class="text-primary font-mono text-[10px] opacity-40 transition-opacity group-hover:opacity-100 group-[.active]:opacity-100"
                    >0{{ forloop.index }}_</span
                  >
                  <span class="text-foreground font-headline group-hover:text-primary group-[.active]:text-primary text-xl font-bold tracking-tight uppercase italic transition-colors lg:text-2xl">
                    {{ question }}
                  </span>
                </span>

                <div class="faq-icon relative h-5 w-5 shrink-0">
                  <span
                    class="bg-foreground absolute inset-0 m-auto h-[1.5px] w-full transition-transform duration-500 group-[.active]:rotate-[225deg]"
                  ></span>
                  <span
                    class="bg-foreground absolute inset-0 m-auto h-full w-[1.5px] transition-transform duration-500 group-[.active]:rotate-[225deg]"
                  ></span>
                </div>
              </button>

              <div class="faq-content max-h-0 overflow-hidden transition-all duration-500 ease-in-out group-[.active]:max-h-[200px]">
                <div class="pb-10 pl-16 lg:pl-20">
                  <p class="text-muted-foreground font-body max-w-xl text-sm leading-relaxed tracking-tight uppercase">
                    {{ answers[forloop.index0] }}
                  </p>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>
